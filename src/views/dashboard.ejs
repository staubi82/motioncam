<% title = 'Dashboard'; pageCSS = 'dashboard'; pageJS = 'dashboard'; %>
<div class="dashboard-grid">
  <div class="stat-card">
    <div class="stat-label">Aufnahmen gesamt</div>
    <div class="stat-value"><%= stats.totalRecordings %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Heute</div>
    <div class="stat-value"><%= stats.todayCount %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Gesamtdauer</div>
    <div class="stat-value"><%= Math.round(stats.totalDuration / 60) %> min</div>
  </div>
  <div class="stat-card" id="stat-disk">
    <div class="stat-label">Speicher</div>
    <div class="stat-value">…</div>
  </div>
  <div class="stat-card stat-card--status">
    <div class="stat-label">Status</div>
    <div class="stat-value">
      <span class="badge badge--<%= stats.isRecording ? 'danger' : 'success' %>">
        <%= stats.isRecording ? 'Aufnahme läuft' : 'Bereit' %>
      </span>
    </div>
  </div>
  <div class="stat-card" id="stat-cpu">
    <div class="stat-label">CPU</div>
    <div class="stat-value">…</div>
  </div>
  <div class="stat-card" id="stat-ram">
    <div class="stat-label">RAM</div>
    <div class="stat-value">…</div>
  </div>
  <div class="stat-card" id="stat-temp">
    <div class="stat-label">Temperatur</div>
    <div class="stat-value">…</div>
  </div>
</div>
<% if (stats.favoriteRecordings && stats.favoriteRecordings.length > 0) { %>
  <div class="favorites-section">
    <div class="favorites-header">
      <h2>Favoriten</h2>
      <a href="/archive?favorites=1" class="btn btn--sm btn--secondary">Alle Favoriten →</a>
    </div>
    <div class="fav-grid">
      <% for (const rec of stats.favoriteRecordings) { %>
        <a href="/videos/<%= rec.id %>" class="fav-thumb" title="<%= rec.filename %> · <%= new Date(rec.created_at).toLocaleString('de-DE') %>">
          <% if (rec.thumbnail_path) { %>
            <img src="/thumbnails/<%= rec.thumbnail_path.split('/').pop() %>" alt="">
          <% } else { %>
            <span class="fav-thumb__empty">☆</span>
          <% } %>
        </a>
      <% } %>
    </div>
  </div>
<% } %>
<% if (stats.latestRecordings && stats.latestRecordings.length > 0) { %>
  <div class="latest-recording">
    <h2>Letzte Aufnahmen</h2>
    <div class="fav-grid">
      <% for (const rec of stats.latestRecordings) { %>
        <a href="/videos/<%= rec.id %>" class="fav-thumb">
          <% if (rec.thumbnail_path) { %>
            <img src="/thumbnails/<%= rec.thumbnail_path.split('/').pop() %>" alt="">
          <% } else { %>
            <span class="fav-thumb__empty">▶</span>
          <% } %>
          <span class="fav-thumb__date"><%= new Date(rec.created_at).toLocaleString('de-DE', {day:'2-digit',month:'2-digit',hour:'2-digit',minute:'2-digit'}) %></span>
        </a>
      <% } %>
    </div>
  </div>
<% } %>
