<% title = 'Archiv'; pageCSS = 'archive'; pageJS = 'archive'; %>

<div class="archive-header">
  <h1>Archiv</h1>
  <div class="archive-header__actions">
    <span class="archive-count"><%= total %> Aufnahmen</span>
    <select id="per-page-select" class="archive-per-page">
      <% [8, 16, 24, 48].forEach(n => { %>
        <option value="<%= n %>" <%= perPage === n ? 'selected' : '' %>><%= n %> pro Seite</option>
      <% }) %>
    </select>
    <button class="btn btn--sm btn--secondary" id="select-mode-btn">Auswählen</button>
    <a href="/archive<%= favoritesActive ? '' : '?favorites=1' %>&per_page=<%= perPage %>"
       class="btn btn--sm <%= favoritesActive ? 'btn--primary' : 'btn--secondary' %>">
      ★ Favoriten
    </a>
  </div>
</div>

<div class="selection-toolbar" id="selection-toolbar">
  <label class="select-all-label">
    <input type="checkbox" id="select-all">
    <span>Alle</span>
  </label>
  <span class="selected-count" id="selected-count">0 ausgewählt</span>
  <div class="selection-toolbar__right">
    <button class="btn btn--danger btn--sm" id="bulk-delete-btn" disabled>Löschen</button>
    <button class="btn btn--secondary btn--sm" id="cancel-select-btn">Abbrechen</button>
  </div>
</div>

<% if (recordings.length === 0) { %>
  <p class="empty-state">Keine Aufnahmen vorhanden.</p>
<% } else { %>
  <div class="archive-grid" id="archive-grid">
    <% for (const rec of recordings) { %>
      <div class="recording-card" data-id="<%= rec.id %>">
        <label class="card-checkbox">
          <input type="checkbox" class="card-check" value="<%= rec.id %>">
          <span class="card-checkbox__mark">
            <svg viewBox="0 0 12 10" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 5 4.5 8.5 11 1"/></svg>
          </span>
        </label>
        <a href="/videos/<%= rec.id %>" class="recording-card__link">
          <% if (rec.thumbnail_path) { %>
            <img src="/thumbnails/<%= rec.thumbnail_path.split('/').pop() %>" alt="" class="recording-card__thumb">
          <% } else { %>
            <div class="recording-card__no-thumb">Kein Thumbnail</div>
          <% } %>
          <div class="recording-card__info">
            <div class="recording-card__name"><%= rec.filename %></div>
            <div class="recording-card__date"><%= new Date(rec.created_at).toLocaleString('de-DE') %></div>
            <% if (rec.duration_seconds) { %><div class="recording-card__dur"><%= Math.round(rec.duration_seconds) %>s</div><% } %>
          </div>
        </a>
        <div class="recording-card__actions">
          <button class="btn btn--icon star-btn" data-id="<%= rec.id %>" data-favorite="<%= rec.is_favorite %>">
            <%= rec.is_favorite ? '⭐' : '☆' %>
          </button>
          <button class="btn btn--danger btn--sm delete-btn" data-id="<%= rec.id %>">Löschen</button>
        </div>
      </div>
    <% } %>
  </div>

  <div class="pagination">
    <% if (page > 1) { %>
      <a href="/archive?page=<%= page - 1 %>&per_page=<%= perPage %><%= favoritesActive ? '&favorites=1' : '' %>" class="btn btn--secondary">Zurück</a>
    <% } %>
    <span>Seite <%= page %> / <%= totalPages %></span>
    <% if (page < totalPages) { %>
      <a href="/archive?page=<%= page + 1 %>&per_page=<%= perPage %><%= favoritesActive ? '&favorites=1' : '' %>" class="btn btn--secondary">Weiter</a>
    <% } %>
  </div>
<% } %>

<!-- Delete Modal -->
<div class="modal-overlay" id="delete-modal" aria-hidden="true">
  <div class="modal" role="dialog" aria-modal="true">
    <div class="modal__icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>
        <path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/>
      </svg>
    </div>
    <h2 class="modal__title" id="modal-title">Aufnahme löschen?</h2>
    <p class="modal__body" id="modal-body">Diese Aufnahme wird unwiderruflich gelöscht.</p>
    <div class="modal__actions">
      <button class="btn btn--secondary" id="modal-cancel">Abbrechen</button>
      <button class="btn btn--danger" id="modal-confirm">Löschen</button>
    </div>
  </div>
</div>
