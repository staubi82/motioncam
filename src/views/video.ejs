<% title = 'Video'; pageCSS = 'archive'; %>
<div class="video-detail">
  <a href="<%= archiveUrl %>" class="btn btn--secondary btn--back">&larr; Zurück</a>
  <h1 class="video-title"><%= recording.filename %></h1>
  <video class="video-player" controls preload="metadata" autoplay playsinline>
    <source src="/videos/<%= recording.id %>/download" type="video/mp4">
  </video>

  <% if (prevRecording || nextRecording) { %>
    <div class="video-neighbors">
      <% if (prevRecording) { %>
        <a class="video-neighbor" href="<%= prevUrl %>">
          <div class="video-neighbor__label">← Vorheriges</div>
          <% if (prevRecording.thumbnail_path) { %>
            <img src="/thumbnails/<%= prevRecording.thumbnail_path.split('/').pop() %>" alt="" class="video-neighbor__thumb">
          <% } else { %>
            <div class="video-neighbor__thumb video-neighbor__thumb--empty">Kein Thumbnail</div>
          <% } %>
          <div class="video-neighbor__name"><%= prevRecording.filename %></div>
          <div class="video-neighbor__meta"><%= new Date(prevRecording.created_at).toLocaleString('de-DE') %></div>
        </a>
      <% } else { %>
        <div class="video-neighbor video-neighbor--placeholder"></div>
      <% } %>

      <% if (nextRecording) { %>
        <a class="video-neighbor" href="<%= nextUrl %>">
          <div class="video-neighbor__label">Nächstes →</div>
          <% if (nextRecording.thumbnail_path) { %>
            <img src="/thumbnails/<%= nextRecording.thumbnail_path.split('/').pop() %>" alt="" class="video-neighbor__thumb">
          <% } else { %>
            <div class="video-neighbor__thumb video-neighbor__thumb--empty">Kein Thumbnail</div>
          <% } %>
          <div class="video-neighbor__name"><%= nextRecording.filename %></div>
          <div class="video-neighbor__meta"><%= new Date(nextRecording.created_at).toLocaleString('de-DE') %></div>
        </a>
      <% } else { %>
        <div class="video-neighbor video-neighbor--placeholder"></div>
      <% } %>
    </div>
  <% } %>

  <div class="video-meta">
    <% if (recording.duration_seconds) { %><div>Dauer: <%= Math.round(recording.duration_seconds) %>s</div><% } %>
    <% if (recording.width) { %><div>Auflösung: <%= recording.width %>×<%= recording.height %></div><% } %>
    <% if (recording.file_size) { %><div>Größe: <%= (recording.file_size / 1024 / 1024).toFixed(1) %> MB</div><% } %>
    <div>Aufgenommen: <%= new Date(recording.created_at).toLocaleString('de-DE') %></div>
  </div>
  <div class="video-actions">
    <a href="/videos/<%= recording.id %>/download" download class="btn btn--primary">Herunterladen</a>
    <% if (!trashActive) { %>
      <button id="star-btn" class="btn btn--icon"
        data-id="<%= recording.id %>"
        data-favorite="<%= recording.is_favorite %>">
        <%= recording.is_favorite ? '⭐' : '☆' %>
      </button>
      <button
        id="delete-btn"
        class="btn btn--danger"
        data-id="<%= recording.id %>"
        data-permanent="0"
        <%= recording.is_favorite ? 'disabled title="Favoriten sind geschützt"' : '' %>
      >
        In Papierkorb
      </button>
    <% } else { %>
      <button id="restore-btn" class="btn btn--secondary" data-id="<%= recording.id %>">Wiederherstellen</button>
      <button id="delete-btn" class="btn btn--danger" data-id="<%= recording.id %>" data-permanent="1">Endgültig löschen</button>
    <% } %>
  </div>
</div>

<div class="modal-overlay" id="video-modal" aria-hidden="true">
  <div class="modal" role="dialog" aria-modal="true">
    <div class="modal__icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>
        <path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/>
      </svg>
    </div>
    <h2 class="modal__title" id="video-modal-title">Aktion bestätigen</h2>
    <p class="modal__body" id="video-modal-body">Bitte bestätigen.</p>
    <div class="modal__actions">
      <button class="btn btn--secondary" id="video-modal-cancel">Abbrechen</button>
      <button class="btn btn--danger" id="video-modal-confirm">Bestätigen</button>
    </div>
  </div>
</div>

<script>
  const modal = document.getElementById('video-modal');
  const modalTitle = document.getElementById('video-modal-title');
  const modalBody = document.getElementById('video-modal-body');
  const modalCancel = document.getElementById('video-modal-cancel');
  const modalConfirm = document.getElementById('video-modal-confirm');
  const defaultConfirmText = modalConfirm?.textContent || 'Bestätigen';
  const defaultCancelText = modalCancel?.textContent || 'Abbrechen';
  let pendingAction = null;

  function openModal({ title, body, onConfirm, confirmLabel, cancelLabel, hideCancel = false }) {
    modalTitle.textContent = title;
    modalBody.textContent = body;
    pendingAction = onConfirm || (async () => {});
    modalConfirm.textContent = confirmLabel || defaultConfirmText;
    modalCancel.textContent = cancelLabel || defaultCancelText;
    modalCancel.style.display = hideCancel ? 'none' : '';
    modal.classList.add('is-open');
    modal.setAttribute('aria-hidden', 'false');
    modalConfirm.focus();
  }

  function closeModal() {
    modal.classList.remove('is-open');
    modal.setAttribute('aria-hidden', 'true');
    modalConfirm.textContent = defaultConfirmText;
    modalCancel.textContent = defaultCancelText;
    modalCancel.style.display = '';
    pendingAction = null;
  }

  function openInfoModal(title, body) {
    openModal({
      title,
      body,
      confirmLabel: 'OK',
      hideCancel: true,
    });
  }

  modalCancel.addEventListener('click', closeModal);
  modal.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });
  modalConfirm.addEventListener('click', async () => {
    if (!pendingAction) return;
    const action = pendingAction;
    closeModal();
    await action();
  });

  document.getElementById('delete-btn').addEventListener('click', async function() {
    const permanent = this.dataset.permanent === '1';
    openModal({
      title: permanent ? 'Aufnahme endgültig löschen?' : 'In Papierkorb verschieben?',
      body: permanent
        ? 'Diese Aufnahme wird endgültig gelöscht.'
        : 'Diese Aufnahme wird in den Papierkorb verschoben.',
      confirmLabel: permanent ? 'Endgültig löschen' : 'Verschieben',
      onConfirm: async () => {
        const url = permanent ? ('/videos/' + this.dataset.id + '?permanent=1') : ('/videos/' + this.dataset.id);
        const res = await fetch(url, { method: 'DELETE' });
        if (res.ok) {
          window.location.href = '<%= archiveUrl %>';
          return;
        }
        let data = {};
        try { data = await res.json(); } catch {}
        openInfoModal('Aktion fehlgeschlagen', data.message || 'Löschen fehlgeschlagen');
      },
    });
  });

  document.getElementById('restore-btn')?.addEventListener('click', async function() {
    const res = await fetch('/videos/' + this.dataset.id + '/restore', { method: 'PATCH' });
    if (res.ok) {
      window.location.href = '<%= archiveUrl %>';
      return;
    }
    let data = {};
    try { data = await res.json(); } catch {}
    openInfoModal('Aktion fehlgeschlagen', data.message || 'Wiederherstellen fehlgeschlagen');
  });

  document.getElementById('star-btn')?.addEventListener('click', async function() {
    const id = this.dataset.id;
    const current = this.dataset.favorite === '1';
    const next = current ? 0 : 1;
    try {
      const res = await fetch(`/api/recordings/${id}/favorite`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ is_favorite: next }),
      });
      if (res.ok) {
        this.dataset.favorite = String(next);
        this.textContent = next === 1 ? '⭐' : '☆';
      } else {
        openInfoModal('Aktion fehlgeschlagen', 'Fehler beim Aktualisieren');
      }
    } catch {
      openInfoModal('Aktion fehlgeschlagen', 'Fehler beim Aktualisieren');
    }
  });
</script>
